{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i src/assets/css/main.css -o _site/assets/css/main.css --minify",
    "build:eleventy": "eleventy",
    "build": "npm run build:css && npm run build:eleventy",
    "dev:css": "tailwindcss -i src/assets/css/main.css -o _site/assets/css/main.css --watch",
    "dev:eleventy": "eleventy --serve",
    "dev": "npm run dev:css & npm run dev:eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
