<section id="projetos" class="mb-12">
  <h2 class="text-2xl font-bold mb-4">projetos</h2>
  <div class="flex flex-col gap-4 text-justify">
    {% for project in profile.projects %}
    <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer" class="block border border-stone-800 rounded-lg p-5 hover:border-accent transition-colors duration-300">
      <h3 class="text-lg font-semibold mb-2 text-accent flex items-center gap-2">
        {{ project.title }}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6"></path>
          <path d="M11 13l9 -9"></path>
          <path d="M15 4h5v5"></path>
        </svg>
      </h3>
      <p class="text-stone-300">{{ project.description }}</p>
    </a>
    {% endfor %}
  </div>
</section>
