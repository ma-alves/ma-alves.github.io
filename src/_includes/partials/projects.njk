<section id="projetos" class="mt-16">
  <h2 class="text-2xl font-bold mb-4">projetos</h2>
  <div class="flex flex-col gap-4 text-justify">
    {% for project in profile.projects %}
    <div class="border border-stone-800 rounded-lg p-5 hover:border-accent transition-colors duration-300">
      <h3 class="text-lg font-semibold mb-2 text-accent">{{ project.title }}</h3>
      <p class="text-stone-300">{{ project.description }}</p>
    </div>
    {% endfor %}
  </div>
</section>
