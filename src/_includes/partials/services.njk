<section id="servicos" class="mb-12">
  <h2 class="text-2xl font-bold mb-4">meus serviços</h2>
  <div class="flex flex-col gap-4">
    {% for service in profile.services %}
    <div class="border border-stone-800 rounded-lg p-5 hover:border-accent transition-colors duration-300">
      <h3 class="text-lg font-semibold mt-2 mb-2 text-accent">{{ service.title }}</h3>
      <p class="text-stone-300">{{ service.description }}</p>
    </div>
    {% endfor %}
  </div>
</section>
