<section class="mb-12">
  <h2 class="text-2xl font-semibold mb-4">trabalho com essas tecnologias</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {% for category in profile.stack %}
    <div class="border border-stone-800 rounded-lg p-4 hover:border-accent transition-colors duration-300">
      <h4 class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">{{ category.category }}</h4>
      <ul class="flex flex-col gap-1.5">
        {% for item in category.items %}
        <li class="text-stone-300 font-mono text-sm">> {{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
    <div class="border border-stone-800 rounded-lg p-4 flex items-center justify-center hover:border-accent transition-colors duration-300">
      <span class="text-5xl text-accent">⚹</span>
    </div>
  </div>
</section>
